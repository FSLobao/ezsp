# Environment variables — copy this to .env and fill in your values
# NEVER commit .env to source control

# Azure AD app registration
AZURE_TENANT_ID=your-tenant-id-here
AZURE_CLIENT_ID=your-client-id-here
AZURE_CLIENT_SECRET=your-client-secret-here

# Graph auth mode
# Values: client_credentials | delegated
GRAPH_AUTH_MODE=client_credentials

# Delegated mode settings
# Used when GRAPH_AUTH_MODE=delegated
AZURE_REDIRECT_URI=http://localhost
# Values: interactive | device_code
GRAPH_DELEGATED_LOGIN_MODE=interactive
# Optional override (space or comma separated)
# GRAPH_DELEGATED_SCOPES=https://graph.microsoft.com/Sites.Selected offline_access openid profile

# SharePoint site (e.g. contoso.sharepoint.com,guid,guid  or  contoso.sharepoint.com:/sites/MySite:)
SHAREPOINT_SITE_ID=your-site-id-here

# Document library drive ID (find via GET /sites/{site-id}/drives)
SHAREPOINT_DRIVE_ID=your-drive-id-here

# SharePoint list ID (find via GET /sites/{site-id}/lists)
SHAREPOINT_LIST_ID=your-list-id-here